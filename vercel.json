{
  "rewrites": [
    { "source": "/pocket", "destination": "/index-pocket.html" },
    { "source": "/linkedin", "destination": "/index-pocket.html" },
    { "source": "/completo", "destination": "/curriculo-completo.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
